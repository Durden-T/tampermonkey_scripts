{
  "name": "discord-thread-monitor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Tampermonkey userscript that monitors Discord forum thread titles for changes",
  "author": "Tyler",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:dev": "tsc && vite build --mode development",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "pako": "^2.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/pako": "^2.0.4",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react-swc": "^3.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^27.4.0",
    "terser": "^5.46.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vite-plugin-monkey": "^7.1.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
